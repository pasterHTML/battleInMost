-- === ГОРЯЧИЕ КЛАВИШИ ===
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    
    if input.KeyCode == Enum.KeyCode.F1 then
        mainFrame.Visible = not mainFrame.Visible
    elseif input.KeyCode == Enum.KeyCode.G then
        settings.AutoClicker = not settings.AutoClicker
        updateButton(autoClickerBtn, settings.AutoClicker)
    elseif input.KeyCode == Enum.KeyCode.T then
        settings.Aimbot = not settings.Aimbot
        updateButton(aimbotBtn, settings.Aimbot)
    elseif input.KeyCode == Enum.KeyCode.K then
        settings.KillAura = not settings.KillAura
        updateButton(killAuraBtn, settings.KillAura)
    elseif input.KeyCode == Enum.KeyCode.Y then
        settings.AntiKnockback = not settings.AntiKnockback
        updateButton(antiKnockBtn, settings.AntiKnockback)
        lastPos = nil
    end
end)

-- === ОСНОВНЫЕ ЦИКЛЫ ===
spawn(function()
    while true do
        if settings.AutoClicker then doAutoClick() end
        wait(settings.ClickSpeed)
    end
end)

RunService.RenderStepped:Connect(function()
    if settings.Aimbot then doAimbot() end
    if settings.KillAura then doKillAura() end
    if settings.AntiKnockback then doAntiKnockback() end
end)

