-- Проверка видимости
local function isTargetVisible(targetPart)
    if not settings.CheckWalls then return true end
    
    local origin = workspace.CurrentCamera.CFrame.Position
    local direction = (targetPart.Position - origin).Unit
    local ray = Ray.new(origin, direction * 1000)
    local hit, pos = workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character})
    
    if hit then
        local hitParent = hit.Parent
        while hitParent do
            if hitParent:IsA("Model") then
                local player = Players:GetPlayerFromCharacter(hitParent)
                if player and player ~= LocalPlayer then
                    return true
                end
            end
            hitParent = hitParent.Parent
        end
        return false
    end
    return true
end

-- Аимбот
local function isFriend(name)
    for _, f in ipairs(settings.Friends) do
        if f:lower() == name:lower() then return true end
    end
    return false
end

local function getAimbotTarget()
    local nearest, nearestDist = nil, settings.AimbotRadius
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and not isFriend(p.Name) then
            local part = p.Character:FindFirstChild("Head") or p.Character:FindFirstChild("HumanoidRootPart")
            if part then
                local dist = (myRoot.Position - part.Position).Magnitude
                if dist < nearestDist and isTargetVisible(part) then
                    nearestDist, nearest = dist, p
                end
            end
        end
    end
    return nearest
end

local function doAimbot()
    if not settings.Aimbot then return end
    local target = getAimbotTarget()
    if target and target.Character then
        local part = target.Character:FindFirstChild("Head") or target.Character:FindFirstChild("HumanoidRootPart")
        if part then
            workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, part.Position)
        end
    end
end

-- === КИЛЛ АУРА С 4 МЕТОДАМИ ===
local function findRemoteEvent()
    -- Ищем RemoteEvent для удара
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("RemoteEvent") and obj.Name:lower():find("attack") or obj.Name:lower():find("hit") or obj.Name:lower():find("damage") then
            return obj
        end
    end
    return nil
end

local function attackWithMethod(target, method)
    if not target or not target.Character then return end
    
    local rootPart = target.Character:FindFirstChild("HumanoidRootPart") or target.Character:FindFirstChild("Torso")
    if not rootPart then return end
    
    if method == 1 then  -- MOUSE1
        pcall(mouse1click)
        
    elseif method == 2 then  -- REMOTE
        local remote = findRemoteEvent()
        if remote then
            pcall(function()
                remote:FireServer(rootPart)
            end)
        end
        
    elseif method == 3 then  -- TOOL
        local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool then
            pcall(function()
                tool:Activate()
            end)
        end
        
    elseif method == 4 then  -- RAY
        -- Эмулируем удар через луч
        pcall(function()
            local ray = Ray.new(workspace.CurrentCamera.CFrame.Position, (rootPart.Position - workspace.CurrentCamera.CFrame.Position).Unit * 1000)
            local hit = workspace:FindPartOnRay(ray, LocalPlayer.Character)
            if hit and hit.Parent then
                local player = Players:GetPlayerFromCharacter(hit.Parent)
                if player == target then
                    mouse1click()
                end
            end
        end)
    end
end

local function getKillAuraTarget()
    local nearest, nearestDist = nil, settings.KillAuraRadius
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and not isFriend(p.Name) then
            local part = p.Character:FindFirstChild("HumanoidRootPart") or p.Character:FindFirstChild("Torso")
            if part then
                local dist = (myRoot.Position - part.Position).Magnitude
                if dist < nearestDist then
                    nearestDist, nearest = dist, p
                end
            end
        end
    end
    return nearest
end

local function doKillAura()
    if not settings.KillAura then return end
    
    local currentTime = tick()
    if currentTime - lastAttackTime < attackCooldown then return end
    
    local target = getKillAuraTarget()
    if target then
        attackWithMethod(target, settings.KillMethod)
        lastAttackTime = currentTime
    end
end

-- Анти-нокбэк
local function doAntiKnockback()
    if not settings.AntiKnockback then return end
    
    local char = LocalPlayer.Character
    if not char then 
        lastPos = nil
        return 
    end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        lastPos = nil
        return
    end
    
    local currentPos = root.Position
    
    if not lastPos then
        lastPos = currentPos
        return
    end
    
    local distance = (currentPos - lastPos).Magnitude
    
    if distance > 15 and humanoid.MoveDirection.Magnitude < 0.1 then
        root.CFrame = CFrame.new(lastPos)
    else
        if distance < 10 then
            lastPos = currentPos
        end
    end
end

