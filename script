-- Проверка видимости через стены
local function isTargetVisible(targetPart)
    if not settings.CheckWalls then return true end
    
    local origin = workspace.CurrentCamera.CFrame.Position
    local direction = (targetPart.Position - origin).Unit
    local ray = Ray.new(origin, direction * 1000)
    local hit, pos = workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character})
    
    if hit then
        local hitParent = hit.Parent
        while hitParent do
            if hitParent:IsA("Model") then
                local player = Players:GetPlayerFromCharacter(hitParent)
                if player and player ~= LocalPlayer then
                    return true  -- Это цель, значит видна
                end
            end
            hitParent = hitParent.Parent
        end
        return false  -- Препятствие не игрок
    end
    return true
end

-- Аимбот с радиусом и проверкой стен
local function isFriend(name)
    for _, f in ipairs(settings.Friends) do
        if f:lower() == name:lower() then return true end
    end
    return false
end

local function getTarget()
    local nearest, nearestDist = nil, settings.AimbotRadius
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and not isFriend(p.Name) then
            local part = p.Character:FindFirstChild("Head") or p.Character:FindFirstChild("HumanoidRootPart")
            if part then
                local dist = (myRoot.Position - part.Position).Magnitude
                if dist < nearestDist and isTargetVisible(part) then
                    nearestDist, nearest = dist, p
                end
            end
        end
    end
    return nearest
end

local function doAimbot()
    if not settings.Aimbot then return end
    local target = getTarget()
    if target and target.Character then
        local part = target.Character:FindFirstChild("Head") or target.Character:FindFirstChild("HumanoidRootPart")
        if part then
            workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, part.Position)
        end
    end
end

-- Анти-нокбэк
local function doAntiKnockback()
    if not settings.AntiKnockback then return end
    
    local char = LocalPlayer.Character
    if not char then 
        lastPos = nil
        return 
    end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        lastPos = nil
        return
    end
    
    local currentPos = root.Position
    
    if not lastPos then
        lastPos = currentPos
        return
    end
    
    local distance = (currentPos - lastPos).Magnitude
    
    if distance > 15 and humanoid.MoveDirection.Magnitude < 0.1 then
        root.CFrame = CFrame.new(lastPos)
    else
        if distance < 10 then
            lastPos = currentPos
        end
    end
end

